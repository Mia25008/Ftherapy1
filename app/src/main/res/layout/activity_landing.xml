<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF7F6"
    tools:context=".screens.LandingActivity">



    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FDEBE9" />

    <LinearLayout
        android:id="@+id/linearLayoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="100dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:srcCompat="@drawable/logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/rubik_semibold"
            android:text="אפרת לוזיק"
            android:textColor="#4A4A4A"
            android:textSize="32sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/rubik"
            android:text="מטפלת ומאמנת הוליסטית"
            android:textColor="#5D4037"
            android:textSize="16sp"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_landing_go_to_register"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/rubik_semibold"
        android:text="הרשמה למערכת"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textAllCaps="false"
        app:backgroundTint="#A57C7C"
        app:cornerRadius="30dp"
        app:elevation="4dp"
        app:layout_constraintBottom_toTopOf="@+id/button_landing_go_to_login"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_landing_go_to_login"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:layout_marginBottom="60dp"
        android:fontFamily="@font/rubik_semibold"
        android:text="התחברות למשתמש קיים"
        android:textColor="#A57C7C"
        android:textSize="16sp"
        android:textAllCaps="false"
        app:cornerRadius="30dp"
        app:strokeColor="#A57C7C"
        app:strokeWidth="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>